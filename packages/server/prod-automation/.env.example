# ─── Platform Database ───────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/byoc
MONGODB_DATABASE=byoc_platform

# ─── AWS (Platform Account) ─────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ─── Pulumi State ───────────────────────────────────────────────
PULUMI_BACKEND_URL=s3://your-pulumi-state-bucket?region=us-east-1
PULUMI_SECRETS_PROVIDER=awskms://alias/your-kms-alias?region=us-east-1

# ─── GitHub (GitOps) ────────────────────────────────────────────
GITHUB_PAT=ghp_...
GITHUB_REPO=your-org/your-gitops-repo
GITHUB_BRANCH=main

# ─── GitHub ArgoCD Token (passed to customer clusters for cortex app) ──────────
GITHUB_ARGOCD_CD_TOKEN=ghp_.

# ─── Config Encryption ──────────────────────────────────────────
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONFIG_ENCRYPTION_KEY=

# ─── Auth ────────────────────────────────────────────────────────
JWT_SECRET=generate-a-strong-random-string
JWT_EXPIRES_IN_HOURS=168

# ─── CORS ────────────────────────────────────────────────────────
CORS_ORIGINS=https://your-frontend.vercel.app

# ─── Celery Monitoring ──────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=changeme

# ─── Service Passwords (passed to customer clusters) ────────────
FALKORDB_PASSWORD=
MILVUS_TOKEN=

# ─── NextJS Secrets (passed to customer clusters) ───────────────
NEXTJS_NEXTAUTH_SECRET=
NEXTJS_GOOGLE_CLIENT_ID=
NEXTJS_GOOGLE_CLIENT_SECRET=
NEXTJS_AUTH_DYNAMODB_ID=
NEXTJS_AUTH_DYNAMODB_SECRET=
NEXTJS_AWS_CONFIG=
NEXTJS_MCP_ENCRYPTION_KEY=
NEXTJS_RESEND_API_KEY=
NEXTJS_STRIPE_SECRET_KEY=
NEXTJS_FRONTEND_CONFIG=
NEXTJS_NEXTAUTH_URL=
NEXTJS_AUTH_DYNAMODB_REGION=us-east-1
NEXTJS_EMAIL_FROM=